<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lin_bg"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/brandTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="随身语音输入助手"
                android:textColor="@color/lin_text"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnHistory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackground"
                android:padding="8dp"
                android:text="历史"
                android:textColor="@color/lin_accent"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/btnSettings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackground"
                android:padding="8dp"
                android:text="设置"
                android:textColor="@color/lin_accent"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/brandSub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="按住说话已改为单击切换 · 对齐 Notion Linear 暗色草稿"
            android:textColor="@color/lin_text_muted"
            android:textSize="12sp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="12dp">

            <View
                android:id="@+id/orbPulse"
                android:layout_width="168dp"
                android:layout_height="168dp"
                android:layout_gravity="center"
                android:alpha="0"
                android:background="@drawable/orb_pulse_ring"
                android:visibility="invisible" />

            <View
                android:id="@+id/orb"
                android:layout_width="112dp"
                android:layout_height="112dp"
                android:layout_gravity="center"
                android:background="@drawable/orb_idle"
                android:clickable="true"
                android:contentDescription="语音球：单击开始或结束识别"
                android:focusable="true" />

            <ProgressBar
                android:id="@+id/orbSpinner"
                style="?android:attr/progressBarStyle"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:indeterminate="true"
                android:indeterminateTint="@color/lin_finalizing"
                android:visibility="gone" />
        </FrameLayout>

        <TextView
            android:id="@+id/phaseChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/chip_background"
            android:paddingLeft="14dp"
            android:paddingTop="6dp"
            android:paddingRight="14dp"
            android:paddingBottom="6dp"
            android:text="Idle"
            android:textColor="@color/lin_text"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="单击语音球开始 · 再单击结束并识别"
            android:textColor="@color/lin_text_muted"
            android:textSize="13sp" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/panel_background"
            android:fillViewport="true"
            android:padding="14dp">

            <TextView
                android:id="@+id/transcript"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="识别结果会显示在这里"
                android:textColor="@color/lin_text"
                android:textColorHint="@color/lin_text_muted"
                android:textIsSelectable="true"
                android:textSize="16sp" />
        </ScrollView>

        <TextView
            android:id="@+id/status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="就绪"
            android:textColor="@color/lin_text_muted"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnCopy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/lin_surface_2"
            android:enabled="false"
            android:text="手动复制"
            android:textAllCaps="false"
            android:textColor="@color/lin_text" />

        <LinearLayout
            android:id="@+id/settingsPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            android:visibility="gone">

            <Button
                android:id="@+id/btnClearHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/lin_surface_2"
                android:text="清空历史（本地尚未持久化）"
                android:textAllCaps="false"
                android:textColor="@color/lin_text" />

            <Button
                android:id="@+id/btnClearCredentials"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:backgroundTint="@color/lin_error"
                android:text="清除凭证"
                android:textAllCaps="false"
                android:textColor="@color/lin_text" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/historyPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/historyList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/panel_background"
                android:padding="12dp"
                android:text="暂无历史。成功识别后会暂存在本会话。"
                android:textColor="@color/lin_text_muted"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
